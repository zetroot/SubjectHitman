{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "IncludeScopes": true,
        "UseUtcTimestamp": true,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ss.fffZ"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=subject_hitman;Username=app;Password=app",
    "RabbitMq": "amqp://guest:guest@localhost:5672"
  },
  "FreeReports": {
    "CooldownPeriod": "1.00:00:00",
    "TimeZone": "Europe/Moscow"
  },
  "Saga": {
    "Timeout": "00:30:00",
    "MaxTimeoutRetries": 5
  },
  "ReportStatusApi": {
    "BaseUrl": "http://localhost:5100",
    "RequestTimeout": "00:00:05"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  }
}
